---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const { pathname } = Astro.url;

const cleanHref = String(href).replace(/\/$/, '');
const cleanPathname = String(pathname).replace(/\/$/, '');
const isActive = cleanHref === cleanPathname || (cleanHref !== '' && cleanHref !== '/' && cleanHref !== import.meta.env.BASE_URL.replace(/\/$/, '') && cleanPathname.startsWith(cleanHref));
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
</style>
