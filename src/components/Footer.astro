---
import { getCollection } from 'astro:content';

const today = new Date();
const posts = await getCollection('blog');
const totalPosts = posts.length;

// Dynamically compute total word count
let totalWords = 0;
posts.forEach(post => {
	const bodyText = post.body || '';
	const cleanText = bodyText.replace(/[\s\r\n#*`_>[\]()\-+!]+/g, '');
	totalWords += cleanText.length;
});

const formattedWords = totalWords >= 1000 ? (totalWords / 1000).toFixed(1) + 'k' : totalWords;
---

<footer class="site-footer">
	<div class="footer-inner">
		<!-- Left info -->
		<div class="footer-left">
			<p>
				<span class="footer-segment">由 <a href="https://astro.build/" target="_blank">Astro</a> 驱动</span>
			</p>
		</div>

		<!-- Center Copyright & Uptime -->
		<div class="footer-center">
			<p>
				<span class="footer-segment">&copy; 2026 - {today.getFullYear()} ❤️ eryuemu</span>
				<span class="divider-dot">·</span>
				<span class="footer-segment">共 {totalPosts} 篇文章</span>
				<span class="divider-dot">·</span>
				<span class="footer-segment">共 {formattedWords} 字</span>
			</p>
			<p class="uptime-row">博客已运行 <span id="uptime" class="highlight-text">0 天 0 小时 0 分钟 0 秒</span></p>
		</div>

		<!-- Right visitor counts -->
		<div class="footer-right">
			<p>
				<span class="footer-segment">访问人数 <span id="visitors-count" class="highlight-text">0</span></span>
				<span class="divider-dot">·</span>
				<span class="footer-segment">总访问量 <span id="views-count" class="highlight-text">0</span></span>
			</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 5rem;
		padding: 2.5rem 1.5rem;
		border-top: 1px solid var(--border);
		font-size: 0.8rem;
		color: var(--text-muted);
		transition: background-color 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.footer-inner {
		max-width: var(--max-width, 960px);
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 2rem;
		flex-wrap: wrap; /* Allows wrapping on medium screens */
	}

	.footer-inner p {
		margin: 0;
		line-height: 1.6;
	}

	.footer-left {
		text-align: left;
		flex: 1;
		min-width: 200px;
	}

	.footer-center {
		text-align: center;
		flex: 1.5;
		min-width: 280px;
	}

	.footer-right {
		text-align: right;
		flex: 1;
		min-width: 200px;
	}

	.uptime-row {
		margin-top: 0.35rem !important;
	}

	.highlight-text {
		color: var(--text-primary);
		font-weight: 500;
	}

	.divider-dot {
		margin: 0 0.4rem;
		color: var(--border-hover);
	}

	.footer-segment {
		white-space: nowrap;
	}

	.footer-inner a {
		color: var(--text-muted);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.footer-inner a:hover {
		color: var(--text-primary);
	}

	@media (max-width: 900px) {
		.footer-inner {
			flex-direction: column;
			text-align: center;
			gap: 1.2rem;
		}

		.footer-left,
		.footer-center,
		.footer-right {
			text-align: center;
			flex: none;
			width: 100%;
			min-width: 0;
		}
	}
</style>

<script>
	let uptimeInterval: number;

	function setupFooterStats() {
		// 1. 运行时间统计 (设为项目在 Vercel 首次部署成功的精确时间：16:42)
		const startDate = new Date('2026-07-18T16:42:00');
		
		function updateUptime() {
			const now = new Date();
			const diff = now.getTime() - startDate.getTime();
			if (diff < 0) return;

			const days = Math.floor(diff / (1000 * 60 * 60 * 24));
			const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
			const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
			const seconds = Math.floor((diff % (1000 * 60)) / 1000);

			const uptimeEl = document.getElementById('uptime');
			if (uptimeEl) {
				uptimeEl.innerText = `${days} 天 ${hours} 小时 ${minutes} 分钟 ${seconds} 秒`;
			}
		}

		const uptimeEl = document.getElementById('uptime');
		if (uptimeEl) {
			if (uptimeInterval) {
				clearInterval(uptimeInterval);
			}
			uptimeInterval = setInterval(updateUptime, 1000);
			updateUptime(); // 立即执行一次
		}

		// 2. 真实访问量统计 (沿用您在 HBU-Wiki 中使用的 Vercount 接口)
		const VERC_COOKIE_PREFIX = 'vercount_uv_';
		const API_URL = 'https://events.vercount.one/api/v2/log';

		function getHostName() {
			return window.location.host || 'unknown-host';
		}

		function getCookieName() {
			const host = getHostName().replace(/[^a-zA-Z0-9_-]/g, '_');
			return `${VERC_COOKIE_PREFIX}${host}`;
		}

		function getCookie(name: string) {
			const cookie = document.cookie.split('; ').find(row => row.startsWith(`${name}=`));
			return cookie ? cookie.substring(name.length + 1) : null;
		}

		function setCookie(name: string, value: string) {
			document.cookie = `${name}=${value}; path=/; max-age=31536000; samesite=lax`;
		}

		async function fetchStats() {
			const hostname = window.location.hostname;
			// 本地开发环境不统计，避免污染生产数据
			if (hostname === 'localhost' || hostname === '127.0.0.1') {
				const visitorsEl = document.getElementById('visitors-count');
				const viewsEl = document.getElementById('views-count');
				if (visitorsEl) visitorsEl.innerText = '1 (本地)';
				if (viewsEl) viewsEl.innerText = '1 (本地)';
				return;
			}

			const cookieName = getCookieName();
			const hasVisited = getCookie(cookieName) === '1';
			const isNewUv = !hasVisited;

			if (isNewUv) {
				setCookie(cookieName, '1');
			}

			try {
				const res = await fetch(API_URL, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json'
					},
					body: JSON.stringify({
						url: window.location.href,
						isNewUv: isNewUv
					})
				});

				if (res.ok) {
					const json = await res.json();
					const data = json.data || json;
					
					const siteUv = Number(data.site_uv || 0);
					const sitePv = Number(data.site_pv || 0);

					const visitorsEl = document.getElementById('visitors-count');
					const viewsEl = document.getElementById('views-count');
					if (visitorsEl) visitorsEl.innerText = siteUv.toLocaleString();
					if (viewsEl) viewsEl.innerText = sitePv.toLocaleString();
				}
			} catch (err) {
				console.error('Failed to fetch stats:', err);
			}
		}

		fetchStats();
	}

	// 监听 Astro 页面加载和切页事件
	document.addEventListener('astro:page-load', setupFooterStats);
</script>
