---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav>
		<a href={import.meta.env.BASE_URL} class="logo">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href={import.meta.env.BASE_URL}>首页</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/blog`}>文章</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/friends`}>友链</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/about`}>关于</HeaderLink>
		</div>
		<div class="nav-right">
			<!-- Theme Toggle Button -->
			<button id="theme-toggle" class="theme-toggle-btn" aria-label="切换主题">
				<svg class="sun-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="5"></circle>
					<line x1="12" y1="1" x2="12" y2="3"></line>
					<line x1="12" y1="21" x2="12" y2="23"></line>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
					<line x1="1" y1="12" x2="3" y2="12"></line>
					<line x1="21" y1="12" x2="23" y2="12"></line>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
				</svg>
				<svg class="moon-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
				</svg>
			</button>

			<a href="https://github.com/eryuemu" target="_blank" aria-label="GitHub" class="icon-link">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 1000;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		transition: background-color 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	:global(html.dark) .site-header {
		background: rgba(10, 10, 10, 0.85);
	}

	nav {
		max-width: var(--max-width, 960px);
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 54px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--text-primary);
		text-decoration: none;
		letter-spacing: -0.01em;
	}
	.logo:hover {
		opacity: 0.7;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	:global(.nav-links a) {
		padding: 0.35rem 0.9rem;
		color: var(--text-secondary) !important;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		border-radius: 6px;
		transition: all 0.15s ease;
	}

	:global(.nav-links a:hover) {
		color: var(--text-primary) !important;
		background: var(--bg-secondary);
		opacity: 1;
	}

	:global(.nav-links a.active) {
		color: var(--text-primary) !important;
		font-weight: 600;
		background: var(--bg-secondary);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.icon-link {
		color: var(--text-muted);
		padding: 0.45rem;
		border-radius: 6px;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.15s ease;
	}

	.icon-link:hover {
		color: var(--text-primary);
		background: var(--bg-secondary);
		opacity: 1;
	}

	/* ─── Theme Toggle Button ─── */
	.theme-toggle-btn {
		background: none;
		border: none;
		padding: 0.45rem;
		cursor: pointer;
		color: var(--text-muted);
		border-radius: 6px;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.15s ease;
	}

	.theme-toggle-btn:hover {
		color: var(--text-primary);
		background: var(--bg-secondary);
	}

	/* Sun/Moon Toggle Rules */
	.sun-icon { display: none; }
	.moon-icon { display: block; }

	:global(html.dark) .sun-icon { display: block; }
	:global(html.dark) .moon-icon { display: none; }

	@media (max-width: 768px) {
		nav {
			padding: 0 1rem;
		}
		.logo {
			font-size: 0.95rem;
		}
		:global(.nav-links a) {
			padding: 0.3rem 0.6rem;
			font-size: 0.85rem;
		}
		/* Allow theme toggle on mobile but hide github */
		.icon-link {
			display: none;
		}
	}
</style>

<script>
	function setupThemeToggle() {
		const toggleBtn = document.getElementById('theme-toggle');
		if (!toggleBtn) return;

		// Clean up existing listener to avoid stacking on navigation swaps
		toggleBtn.replaceWith(toggleBtn.cloneNode(true));
		
		const activeBtn = document.getElementById('theme-toggle');
		if (!activeBtn) return;

		activeBtn.addEventListener('click', () => {
			const isDark = document.documentElement.classList.contains('dark');
			if (isDark) {
				document.documentElement.classList.remove('dark');
				localStorage.setItem('theme', 'light');
			} else {
				document.documentElement.classList.add('dark');
				localStorage.setItem('theme', 'dark');
			}
		});
	}

	// Setup toggle event handler for every navigation swap
	document.addEventListener('astro:page-load', setupThemeToggle);
</script>
