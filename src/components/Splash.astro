<div id="splash-screen">
	<script is:inline>
		if (sessionStorage.getItem('splash-played')) {
			document.getElementById('splash-screen').style.display = 'none';
		}
	</script>
	<div class="splash-content">
		<h1 class="splash-logo">eryuemu's blog</h1>
	</div>
</div>

<style>
	#splash-screen {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background: var(--bg);
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 9999;
		transition: transform 0.9s cubic-bezier(0.85, 0, 0.15, 1);
		pointer-events: none;
	}

	#splash-screen.fade-out {
		transform: translateY(-100%);
	}

	.splash-content {
		text-align: center;
	}

	.splash-logo {
		font-size: 1.8rem;
		font-weight: 300;
		color: var(--text-primary);
		letter-spacing: 0.15em;
		margin: 0;
		opacity: 0;
		animation: revealText 1.1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 0.2s;
	}

	@keyframes revealText {
		0% {
			opacity: 0;
			letter-spacing: 0.12em;
			transform: scale(0.98);
		}
		100% {
			opacity: 1;
			letter-spacing: 0.24em;
			transform: scale(1);
		}
	}
</style>

<script>
	function initSplash() {
		const splash = document.getElementById('splash-screen');
		if (!splash) return;

		if (sessionStorage.getItem('splash-played')) {
			splash.remove();
			return;
		}

		// Slide up and mark as played
		setTimeout(() => {
			splash.classList.add('fade-out');
			sessionStorage.setItem('splash-played', 'true');
			
			setTimeout(() => {
				splash.remove();
			}, 900);
		}, 1300);
	}

	// Initialize
	initSplash();

	// Guard against view-transitions bringing back the splash markup
	document.addEventListener('astro:after-swap', () => {
		const splash = document.getElementById('splash-screen');
		if (splash && sessionStorage.getItem('splash-played')) {
			splash.remove();
		}
	});
</script>
