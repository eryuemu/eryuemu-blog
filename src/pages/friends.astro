---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WalineComments from '../components/WalineComments.astro';
import { SITE_TITLE } from '../consts';
import { friends } from '../data/friends';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`友情链接 — ${SITE_TITLE}`} description="eryuemu（二月木）的博客友情链接与博主朋友们" />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding-top: 7em;
				padding-bottom: 4rem;
			}

			.friends-header {
				margin-bottom: 2.5rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid var(--border);
			}

			.friends-header h1 {
				font-size: 2.2rem;
				font-weight: 700;
				margin: 0 0 0.8rem 0;
				color: var(--text-primary);
			}

			.friends-subtitle {
				font-size: 1.05rem;
				color: var(--text-secondary);
				line-height: 1.6;
				margin: 0;
			}

			/* My Info Card */
			.my-info-card {
				background: var(--bg-secondary);
				border: 1px solid var(--border);
				border-radius: var(--radius, 12px);
				padding: 1.5rem;
				margin-bottom: 3rem;
			}

			.my-info-card h2 {
				font-size: 1.1rem;
				font-weight: 600;
				margin: 0 0 0.6rem 0;
				color: var(--text-primary);
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.my-info-card .hint {
				font-size: 0.85rem;
				color: var(--text-muted);
				margin: 0 0 1rem 0;
				line-height: 1.6;
			}

			.my-info-card .code-block-wrapper {
				position: relative;
				margin: 0;
			}

			.my-info-card .code-block-wrapper pre {
				margin: 0;
				background: var(--bg);
			}

			.my-info-card .copy-code-button {
				opacity: 1;
			}

			/* Friends Grid */
			.friends-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
				gap: 1.25rem;
				margin-bottom: 4rem;
			}

			.friend-card {
				display: flex;
				flex-direction: column;
				background: var(--bg);
				border: 1px solid var(--border);
				border-radius: var(--radius, 12px);
				padding: 1.25rem;
				text-decoration: none;
				transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
				position: relative;
				overflow: hidden;
			}

			.friend-card:hover {
				transform: translateY(-3px);
				border-color: var(--text-muted);
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
			}

			:global(html.dark) .friend-card:hover {
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
			}

			.friend-top {
				display: flex;
				align-items: center;
				gap: 0.9rem;
				margin-bottom: 0.8rem;
			}

			.friend-avatar {
				width: 48px;
				height: 48px;
				border-radius: 50%;
				object-fit: cover;
				background: var(--bg-secondary);
				border: 1px solid var(--border);
				flex-shrink: 0;
			}

			.friend-info {
				flex: 1;
				min-width: 0;
			}

			.friend-name {
				font-size: 1.05rem;
				font-weight: 600;
				color: var(--text-primary);
				margin: 0 0 0.2rem 0;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.friend-desc {
				font-size: 0.88rem;
				color: var(--text-secondary);
				line-height: 1.5;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.friend-tags {
				display: flex;
				gap: 0.4rem;
				margin-top: auto;
				padding-top: 0.8rem;
			}

			.tag {
				font-size: 0.75rem;
				color: var(--text-muted);
				background: var(--bg-secondary);
				padding: 0.15rem 0.5rem;
				border-radius: 4px;
				border: 1px solid var(--border);
			}

			.apply-section {
				background: var(--bg-secondary);
				border: 1px dashed var(--border);
				border-radius: var(--radius, 12px);
				padding: 1.5rem;
				text-align: center;
				margin-bottom: 3rem;
			}

			.apply-section h3 {
				font-size: 1.1rem;
				margin: 0 0 0.5rem 0;
				color: var(--text-primary);
			}

			.apply-section p {
				font-size: 0.92rem;
				color: var(--text-secondary);
				margin: 0;
				line-height: 1.6;
			}

			@media (max-width: 768px) {
				main {
					padding-top: 6em;
				}
				.friends-header h1 {
					font-size: 1.8rem;
				}
				.friends-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="friends-header">
				<h1>🤝 友情链接</h1>
				<p class="friends-subtitle">海内存知己，天涯若比邻。</p>
			</div>

			<!-- Friends Grid -->
			<div class="friends-grid">
				{
					friends.map((friend) => (
						<a href={friend.link} target="_blank" rel="noopener noreferrer" class="friend-card">
							<div class="friend-top">
								<img
									src={friend.logo}
									alt={friend.title}
									class="friend-avatar"
									onerror="this.onerror=null; this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 fill=%22%238882%22/><text x=%2250%22 y=%2255%22 font-size=%2240%22 text-anchor=%22middle%22 dominant-baseline=%22middle%22 fill=%22%23888%22>🔗</text></svg>';"
								/>
								<div class="friend-info">
									<h3 class="friend-name">{friend.title}</h3>
								</div>
							</div>
							<p class="friend-desc">{friend.desc}</p>
							{friend.tags && friend.tags.length > 0 && (
								<div class="friends-tags">
									{friend.tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							)}
						</a>
					))
				}
			</div>

			<!-- My Info Card -->
			<div class="my-info-card">
				<h2>📎 本站名片信息</h2>
				<p class="hint">如需交换友链，请先在贵站添加本站信息，然后复制下方内容在评论区提交。</p>
				<div class="code-block-wrapper">
					<pre><code data-copy="{
  &quot;title&quot;: &quot;eryuemu&#x27;s blog&quot;,
  &quot;link&quot;: &quot;https://eryuemu.com/&quot;,
  &quot;logo&quot;: &quot;https://eryuemu.com/avatar.jpg&quot;,
  &quot;desc&quot;: &quot;事在人为，圆融自洽&quot;
}">&#123;
  "title": "eryuemu's blog",
  "link": "https://eryuemu.com/",
  "logo": "https://eryuemu.com/avatar.jpg",
  "desc": "事在人为，圆融自洽"
&#125;</code></pre>
					<button class="copy-code-button" data-copy-target="my-info-code">复制</button>
				</div>
			</div>
			<div class="apply-section">
				<h3>💬 申请互换友链</h3>
				<p>欢迎各位博主交换友链！请先在贵站添加本站链接，然后在下方评论区留下您的博客名片信息（名称、链接、头像、简介），我看到后会第一时间为您添加！</p>
			</div>

			<WalineComments />
		</main>
		<Footer />
	<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(".copy-code-button").forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", async () => {
        const wrapper = btn.closest(".code-block-wrapper");
        const code = wrapper ? wrapper.querySelector("code") : null;
        if (!code) return;
        const text = code.dataset.copy || code.innerText;
        try {
          await navigator.clipboard.writeText(text);
        } catch (e) {
          const ta = document.createElement("textarea");
          ta.value = text;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          ta.remove();
        }
        const orig = btn.textContent;
        btn.textContent = "已复制";
        setTimeout(() => (btn.textContent = orig), 1500);
      });
    });
  });
</script>
</body>
</html>
