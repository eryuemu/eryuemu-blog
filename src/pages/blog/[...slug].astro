---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Calculate stats dynamically from markdown body
const bodyText = post.body || '';
const cleanText = bodyText.replace(/[\s\r\n#*`_>[\]()\-+!]+/g, '');
const wordCount = cleanText.length;
const readingTime = Math.max(1, Math.ceil(wordCount / 350)); // ~350 chars per minute

---

<BlogPost {...post.data} wordCount={wordCount} readingTime={readingTime}>
	<Content />
</BlogPost>
